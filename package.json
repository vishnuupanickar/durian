{
  "name": "durian",
  "version": "0.1.0",
  "private": true,
  "description": "An open source database management studio for Cloudflare D1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @durian/desktop",
    "build": "npm run build --workspace @durian/desktop",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}

